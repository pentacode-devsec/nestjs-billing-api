<html lang='es'>
  <head>
    <meta charset='UTF-8' />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: Arial, sans-serif;
        font-size: 11px;
        color: #1a1a1a;
        padding: 20px;
      }

      .header {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 16px;
        border-bottom: 2px solid #1e3a5f;
        padding-bottom: 16px;
      }

      .company-info h1 {
        font-size: 16px;
        color: #1e3a5f;
        margin-bottom: 4px;
      }

      .company-info p {
        color: #555;
        line-height: 1.5;
      }

      .invoice-info {
        text-align: right;
      }

      .invoice-badge {
        background: #1e3a5f;
        color: white;
        padding: 8px 16px;
        border-radius: 4px;
        display: inline-block;
        margin-bottom: 8px;
      }

      .invoice-badge h2 {
        font-size: 14px;
        margin-bottom: 2px;
      }

      .invoice-badge p {
        font-size: 12px;
        opacity: 0.9;
      }

      .resolution-info {
        font-size: 10px;
        color: #666;
        line-height: 1.6;
      }

      .parties {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 16px;
      }

      .party-box {
        border: 1px solid #ddd;
        border-radius: 4px;
        padding: 10px;
      }

      .party-box h3 {
        font-size: 10px;
        text-transform: uppercase;
        color: #1e3a5f;
        font-weight: bold;
        margin-bottom: 6px;
        padding-bottom: 4px;
        border-bottom: 1px solid #eee;
      }

      .party-box p {
        line-height: 1.6;
        color: #333;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 16px;
      }

      thead tr {
        background: #1e3a5f;
        color: white;
      }

      thead th {
        padding: 8px 6px;
        text-align: left;
        font-size: 10px;
        text-transform: uppercase;
      }

      thead th.right {
        text-align: right;
      }

      tbody tr:nth-child(even) {
        background: #f5f8fc;
      }

      tbody td {
        padding: 7px 6px;
        border-bottom: 1px solid #eee;
        color: #333;
      }

      tbody td.right {
        text-align: right;
      }

      .totals-section {
        display: grid;
        grid-template-columns: 1fr 280px;
        gap: 20px;
        margin-bottom: 16px;
      }

      .cufe-box {
        border: 1px solid #ddd;
        border-radius: 4px;
        padding: 10px;
        font-size: 9px;
      }

      .cufe-box h3 {
        font-size: 10px;
        color: #1e3a5f;
        font-weight: bold;
        margin-bottom: 6px;
      }

      .cufe-value {
        word-break: break-all;
        color: #444;
        line-height: 1.5;
        font-family: monospace;
      }

      .totals-table {
        border: 1px solid #ddd;
        border-radius: 4px;
        overflow: hidden;
      }

      .totals-table table {
        margin: 0;
      }

      .totals-table td {
        padding: 6px 10px;
        border-bottom: 1px solid #eee;
      }

      .totals-table td:last-child {
        text-align: right;
        font-weight: bold;
      }

      .totals-table .total-row {
        background: #1e3a5f;
        color: white;
      }

      .totals-table .total-row td {
        font-size: 12px;
        border-bottom: none;
      }

      .footer {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 20px;
        border-top: 2px solid #1e3a5f;
        padding-top: 12px;
        align-items: center;
      }

      .footer-text {
        font-size: 9px;
        color: #666;
        line-height: 1.6;
      }

      .qr-section {
        text-align: center;
      }

      .qr-section img {
        width: 80px;
        height: 80px;
      }

      .qr-section p {
        font-size: 8px;
        color: #666;
        margin-top: 4px;
      }
    </style>
  </head>
  <body>

    <!-- CABECERA -->
    <div class='header'>
      <div class='company-info'>
        <h1>{{supplier.name}}</h1>
        <p>NIT: {{supplier.nit}}-{{supplier.dv}}</p>
        <p>{{supplier.address}}, {{supplier.city}}</p>
        <p>{{supplier.department}}, Colombia</p>
        <p>Tel: {{supplier.phone}}</p>
        <p>{{supplier.email}}</p>
      </div>
      <div class='invoice-info'>
        <div class='invoice-badge'>
          <h2>FACTURA ELECTRÓNICA DE VENTA</h2>
          <p>No. {{invoice.id}}</p>
        </div>
        <div class='resolution-info'>
          <p>Fecha: {{invoice.issueDate}} {{invoice.issueTime}}</p>
          <p>Resolución DIAN No. {{resolution.number}}</p>
          <p>Vigencia: {{resolution.startDate}} al {{resolution.endDate}}</p>
          <p>Rango autorizado:
            {{resolution.rangeFrom}}
            -
            {{resolution.rangeTo}}</p>
        </div>
      </div>
    </div>

    <!-- EMISOR Y RECEPTOR -->
    <div class='parties'>
      <div class='party-box'>
        <h3>Emisor</h3>
        <p><strong>{{supplier.name}}</strong></p>
        <p>NIT: {{supplier.nit}}-{{supplier.dv}}</p>
        <p>Régimen: Responsable de IVA</p>
        <p>{{supplier.address}}</p>
        <p>{{supplier.city}}, {{supplier.department}}</p>
      </div>
      <div class='party-box'>
        <h3>Receptor</h3>
        <p><strong>{{customer.name}}</strong></p>
        <p>ID ({{customer.idType}}): {{customer.idNumber}}</p>
        <p>{{customer.address}}</p>
        <p>{{customer.email}}</p>
      </div>
    </div>

    <!-- TABLA DE ITEMS -->
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Código</th>
          <th>Descripción</th>
          <th class='right'>Cant.</th>
          <th class='right'>Precio Unit.</th>
          <th class='right'>Descuento</th>
          <th class='right'>IVA %</th>
          <th class='right'>Total</th>
        </tr>
      </thead>
      <tbody>
        {{#each items}}
          <tr>
            <td>{{lineNumber}}</td>
            <td>{{code}}</td>
            <td>{{description}}</td>
            <td class='right'>{{quantity}}</td>
            <td class='right'>{{formatCurrency unitPrice}}</td>
            <td class='right'>{{formatCurrency discount}}</td>
            <td class='right'>{{firstTaxRate taxes}}%</td>
            <td class='right'>{{formatCurrency lineTotal}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>

    <!-- TOTALES Y CUFE -->
    <div class='totals-section'>
      <div class='cufe-box'>
        <h3>CUFE</h3>
        <p class='cufe-value'>{{invoice.cufe}}</p>
      </div>
      <div class='totals-table'>
        <table>
          <tr>
            <td>Subtotal</td>
            <td>{{formatCurrency invoice.subtotal}}</td>
          </tr>
          <tr>
            <td>Descuentos</td>
            <td>{{formatCurrency invoice.discounts}}</td>
          </tr>
          <tr>
            <td>IVA</td>
            <td>{{formatCurrency invoice.taxTotal}}</td>
          </tr>
          <tr class='total-row'>
            <td>TOTAL COP</td>
            <td>{{formatCurrency invoice.total}}</td>
          </tr>
        </table>
      </div>
    </div>

    <!-- FOOTER -->
    <div class='footer'>
      <div class='footer-text'>
        <p><strong>Forma de pago:</strong> {{paymentMethodLabel}}</p>
        <p>Este documento es la representación gráfica de una Factura
          Electrónica de Venta.</p>
        <p>Generado por nestjs-fiscal-bridge — Pentacode SAS</p>
      </div>
      <div class='qr-section'>
        <img src='{{qrDataUrl}}' alt='QR DIAN' />
        <p>Verificar en DIAN</p>
      </div>
    </div>

  </body>
</html>